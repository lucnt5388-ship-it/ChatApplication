<Window
    x:Class="ChatClient2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Messenger Chat">

    <Grid Background="#0F172A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="#111827" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Messenger Chat"
                           FontSize="25"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,18"/>

                <!-- LOGIN -->
                <Border Grid.Row="1"
                        Background="#1E293B"
                        CornerRadius="18"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBox x:Name="txtUsername"
                                 PlaceholderText="Tài khoản"
                                 Height="42"/>

                        <PasswordBox x:Name="txtPassword"
                                     PlaceholderText="Mật khẩu"
                                     Height="42"/>

                        <Button x:Name="btnLogin"
                                Content="Đăng nhập"
                                Height="44"
                                Background="#2563EB"
                                Foreground="White"
                                Click="btnLogin_Click"/>
                    </StackPanel>
                </Border>

                <!-- STATUS -->
                <Border Grid.Row="2"
                        Background="#1E293B"
                        CornerRadius="18"
                        Padding="14"
                        Margin="0,14,0,14">
                    <StackPanel>
                        <TextBlock x:Name="txtMe"
                                   Text="Chưa đăng nhập"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                        <TextBlock x:Name="txtNetwork"
                                   Text="Ping: --"
                                   FontSize="13"
                                   Foreground="#94A3B8"
                                   Margin="0,4,0,10"/>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnOnline"
                                    Grid.Column="0"
                                    Content="Online"
                                    Background="#16A34A"
                                    Foreground="White"
                                    Click="btnOnline_Click"/>

                            <Button x:Name="btnOffline"
                                    Grid.Column="1"
                                    Content="Offline"
                                    Background="#DC2626"
                                    Foreground="White"
                                    Click="btnOffline_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ONLINE LIST -->
                <StackPanel Grid.Row="3">
                    <TextBlock Text="Người đang online"
                               Foreground="#94A3B8"
                               FontSize="14"
                               Margin="0,0,0,8"/>

                    <ListView x:Name="lstUsers"
                              SelectionChanged="lstUsers_SelectionChanged"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E293B"
                                        CornerRadius="16"
                                        Padding="12"
                                        Margin="0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="38" Height="38">
                                            <Ellipse Fill="#334155"/>
                                            <TextBlock Text="{Binding AvatarText}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <Ellipse Width="11"
                                                     Height="11"
                                                     Fill="#22C55E"
                                                     Stroke="#1E293B"
                                                     StrokeThickness="2"
                                                     HorizontalAlignment="Right"
                                                     VerticalAlignment="Bottom"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Username}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       FontSize="15"/>

                                            <TextBlock Text="Đang hoạt động"
                                                       Foreground="#22C55E"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <TextBlock Grid.Row="4"
                           x:Name="txtStatus"
                           Text="Server: 127.0.0.1:5000"
                           Foreground="#64748B"
                           FontSize="12"
                           Margin="0,12,0,0"/>
            </Grid>
        </Border>

        <!-- CHAT AREA -->
        <Grid Grid.Column="1" Background="#0B1120">
            <Grid.RowDefinitions>
                <RowDefinition Height="76"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="86"/>
            </Grid.RowDefinitions>

            <!-- CHAT HEADER -->
            <Border Grid.Row="0" Background="#111827" Padding="22,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Width="44" Height="44">
                        <Ellipse Fill="#2563EB"/>
                        <TextBlock x:Name="txtChatAvatar"
                                   Text="?"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="txtChatTitle"
                                   Text="Chọn người để chat"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                        <TextBlock x:Name="txtChatSub"
                                   Text="Tin nhắn và file được lưu trên server"
                                   Foreground="#94A3B8"
                                   FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- MESSAGES -->
            <ScrollViewer Grid.Row="1"
                          x:Name="scrollMessages"
                          Padding="22"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="lstMessages">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="{Binding BubbleColumn}"
                                        Background="{Binding BubbleBrush}"
                                        CornerRadius="{Binding BubbleCorner}"
                                        Padding="14"
                                        MaxWidth="540"
                                        HorizontalAlignment="Stretch">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SenderLabel}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Visibility="{Binding SenderVisibility}"/>

                                        <TextBlock Text="{Binding Message}"
                                                   Foreground="White"
                                                   FontSize="15"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,4"/>

                                        <Button Content="Tải file"
                                                Visibility="{Binding DownloadVisibility}"
                                                Tag="{Binding FileId}"
                                                Click="btnDownloadFile_Click"
                                                Margin="0,8,0,0"
                                                Height="34"
                                                Background="#F8FAFC"
                                                Foreground="#111827"/>

                                        <TextBlock Text="{Binding TimeText}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- INPUT -->
            <Border Grid.Row="2" Background="#111827" Padding="18">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="112"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtMessage"
                             Grid.Column="0"
                             PlaceholderText="Nhập tin nhắn..."
                             Height="48"
                             FontSize="15"
                             KeyDown="txtMessage_KeyDown"/>

                    <Button x:Name="btnSendFile"
                            Grid.Column="1"
                            Content="Gửi file"
                            Height="48"
                            Background="#334155"
                            Foreground="White"
                            Click="btnSendFile_Click"/>

                    <Button x:Name="btnSend"
                            Grid.Column="2"
                            Content="Gửi"
                            Height="48"
                            Background="#2563EB"
                            Foreground="White"
                            Click="btnSend_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>