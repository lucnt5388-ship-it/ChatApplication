<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ChatClient2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ChatClient2"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ChatClient2">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#0B1020">
        <Grid.Resources>

            <SolidColorBrush x:Key="SidebarBg" Color="#111827"/>
            <SolidColorBrush x:Key="PanelBg" Color="#0F172A"/>
            <SolidColorBrush x:Key="CardBg" Color="#182338"/>
            <SolidColorBrush x:Key="CardBg2" Color="#1E293B"/>
            <SolidColorBrush x:Key="InputBg" Color="#111C30"/>
            <SolidColorBrush x:Key="PrimaryBrush" Color="#3B82F6"/>
            <SolidColorBrush x:Key="TextMain" Color="#F8FAFC"/>
            <SolidColorBrush x:Key="TextSub" Color="#94A3B8"/>
            <SolidColorBrush x:Key="BorderBrushSoft" Color="#26344D"/>
            <SolidColorBrush x:Key="OnlineBrush" Color="#22C55E"/>

            <Style x:Key="NiceTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource InputBg}"/>
                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="FontSize" Value="15"/>
            </Style>

            <Style x:Key="MainButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="14,12"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Cột trái -->
        <Border Grid.Column="0"
                Margin="16"
                Background="{StaticResource SidebarBg}"
                CornerRadius="22"
                Padding="16">

            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource CardBg}"
                        CornerRadius="18"
                        Padding="14">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Messenger"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMain}"/>
                        <TextBlock Text="Chat realtime bằng TCP Socket"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSub}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Spacing="6">
                    <TextBlock Text="Tên của bạn"
                               Foreground="{StaticResource TextSub}"/>
                    <TextBox x:Name="txtMyName"
                             Style="{StaticResource NiceTextBoxStyle}"
                             PlaceholderText="người dùng nhập tên"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="6">
                    <TextBlock Text="IP Server"
                               Foreground="{StaticResource TextSub}"/>
                    <TextBox x:Name="txtServerIp"
                             Style="{StaticResource NiceTextBoxStyle}"
                             Text="127.0.0.1"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="10">
                    <Button x:Name="btnConnect"
                            Style="{StaticResource MainButtonStyle}"
                            Content="Kết nối"
                            Click="btnConnect_Click"/>

                    <Border Background="{StaticResource CardBg}"
                            CornerRadius="14"
                            Padding="10">
                        <TextBlock Text="Bấm Kết nối trước, rồi chọn người online để chat."
                                   Foreground="{StaticResource TextSub}"
                                   TextWrapping="Wrap"
                                   FontSize="12"/>
                    </Border>
                </StackPanel>

                <Border Grid.Row="4"
                        Background="{StaticResource CardBg}"
                        CornerRadius="18"
                        Padding="12">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Người online"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMain}"/>

                        <ListView x:Name="lstUsers"
                                  Grid.Row="1"
                                  Margin="0,4,0,0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectionChanged="lstUsers_SelectionChanged">

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            CornerRadius="16"
                                            Background="{StaticResource CardBg2}">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid Width="40" Height="40">
                                                <Ellipse Fill="#334155"/>
                                                <TextBlock Text="👤"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{StaticResource TextMain}"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"/>
                                                <TextBlock Text="Đang hoạt động"
                                                           Foreground="{StaticResource TextSub}"
                                                           FontSize="12"/>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Background="#16331F"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Ellipse Width="8"
                                                             Height="8"
                                                             Fill="{StaticResource OnlineBrush}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="Online"
                                                               Foreground="#86EFAC"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Cột phải -->
        <Grid Grid.Column="1" Margin="0,16,16,16" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="82"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="102"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource PanelBg}"
                    CornerRadius="22"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Grid Width="48" Height="48">
                            <Ellipse Fill="#334155"/>
                            <TextBlock Text="💬"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"/>
                        </Grid>

                        <StackPanel>
                            <TextBlock x:Name="txtChatWith"
                                       Text="Chọn người để chat"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMain}"/>
                            <TextBlock Text="Tin nhắn realtime"
                                       Foreground="{StaticResource TextSub}"
                                       FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource CardBg}"
                            CornerRadius="999"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{StaticResource OnlineBrush}"/>
                            <TextBlock Text="Ready"
                                       Foreground="{StaticResource TextSub}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBg}"
                    CornerRadius="22"
                    Padding="14">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource CardBg}"
                            CornerRadius="14"
                            Padding="10">
                        <TextBlock Text="Đây là vùng hiển thị tin nhắn gửi và nhận."
                                   Foreground="{StaticResource TextSub}"
                                   FontSize="12"/>
                    </Border>

                    <ListView x:Name="lstMessages"
                              Grid.Row="1"
                              Margin="0,4,0,0"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Width="34"
                                          Height="34"
                                          Margin="0,0,8,0"
                                          Visibility="{Binding OtherAvatarVisibility}">
                                        <Ellipse Fill="#334155"/>
                                        <TextBlock Text="👤"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                    </Grid>

                                    <Border Grid.Column="{Binding BubbleColumn}"
                                            MaxWidth="680"
                                            Padding="14"
                                            CornerRadius="18"
                                            Background="{Binding BubbleBrush}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding SenderLabel}"
                                                       Foreground="#C7D2FE"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Visibility="{Binding SenderVisibility}"/>
                                            <TextBlock Text="{Binding Message}"
                                                       Foreground="White"
                                                       TextWrapping="WrapWholeWords"
                                                       FontSize="15"
                                                       LineHeight="22"/>
                                            <TextBlock Text="{Binding TimeText}"
                                                       Foreground="#CBD5E1"
                                                       FontSize="11"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelBg}"
                    CornerRadius="22"
                    Padding="14">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Nhập nội dung tin nhắn"
                                   Foreground="{StaticResource TextSub}"
                                   FontSize="12"/>
                        <Border Background="{StaticResource InputBg}"
                                CornerRadius="16"
                                Padding="8">
                            <TextBox x:Name="txtMessage"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextMain}"
                                     FontSize="16"
                                     PlaceholderText="Gõ tin nhắn rồi nhấn Enter..."
                                     KeyDown="txtMessage_KeyDown"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Spacing="6">
                        <Button x:Name="btnSend"
                                Style="{StaticResource MainButtonStyle}"
                                Content="Gửi tin nhắn"
                                FontSize="16"
                                Click="btnSend_Click"/>
                        <TextBlock Text="Chọn người ở bên trái trước."
                                   Foreground="{StaticResource TextSub}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
